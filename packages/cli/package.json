{
  "name": "@localive/cli",
  "version": "0.1.1",
  "description": "Command line tools for Localive translation workflows",
  "license": "MIT",
  "author": "Localive",
  "homepage": "https://localive.vercel.app/cli/overview/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "i18n",
    "cli",
    "translation",
    "localization",
    "extract",
    "localive",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "localive": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@localive/core": "^0.1.1"
  },
  "devDependencies": {
    "@localive/core": "^0.1.1"
  },
  "nx": {
    "tags": [
      "scope:cli",
      "type:lib"
    ]
  }
}

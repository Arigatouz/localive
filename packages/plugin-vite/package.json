{
  "name": "@localive/vite",
  "version": "0.1.2",
  "description": "Vite dev-server plugin for Localive — live in-context i18n editing",
  "license": "MIT",
  "author": "Ali Gamal <aga@luftborn.com> (https://github.com/Arigatouz)",
  "homepage": "https://localive.vercel.app/plugins/vite/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/plugin-vite"
  },
  "keywords": [
    "i18n",
    "vite",
    "vite-plugin",
    "translation",
    "localization",
    "live-editing",
    "localive"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "vite": "^6.3.5",
    "vitest": "^3.1.1",
    "supertest": "^7.1.0",
    "@localive/core": "^0.1.2"
  },
  "nx": {
    "tags": [
      "scope:plugin",
      "type:lib"
    ]
  }
}

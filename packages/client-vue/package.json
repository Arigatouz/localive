{
  "name": "@localive/vue",
  "version": "0.1.3",
  "description": "Vue bindings for Localive. Drop in the provider and fix copy right on the page.",
  "license": "MIT",
  "author": "Ali Gamal <aga@luftborn.com> (https://github.com/Arigatouz)",
  "homepage": "https://localive.vercel.app/guides/vue/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/client-vue"
  },
  "keywords": [
    "i18n",
    "vue",
    "translation",
    "localization",
    "live-editing",
    "localive",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@localive/core": "^0.1.3",
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@localive/core": "^0.1.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-core": "^3.3.4",
    "@vue/test-utils": "^2.4.0",
    "vue": "^3.5.0"
  },
  "nx": {
    "tags": [
      "scope:client:vue",
      "type:lib"
    ]
  }
}

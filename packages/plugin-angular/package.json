{
  "name": "@localive/plugin-angular",
  "version": "0.1.3",
  "description": "Angular CLI builder that lets Localive save translation edits during development.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./builders": {
      "import": "./dist/builders.js",
      "types": "./dist/builders.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "builders.json"
  ],
  "builders": "./builders.json",
  "author": "Ali Gamal <aga@luftborn.com> (https://github.com/Arigatouz)",
  "homepage": "https://localive.vercel.app/plugins/angular/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/plugin-angular"
  },
  "keywords": [
    "i18n",
    "angular",
    "angular-builder",
    "translation",
    "localization",
    "live-editing",
    "localive"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@angular-devkit/build-angular": ">=17",
    "@angular-devkit/architect": ">=0.1700"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular-devkit/architect": "^0.1900.0",
    "@angular-devkit/core": "^19.0.0",
    "@localive/core": "^0.1.3",
    "@localive/vite": "^0.1.3"
  },
  "nx": {
    "tags": [
      "scope:plugin",
      "type:lib"
    ]
  }
}

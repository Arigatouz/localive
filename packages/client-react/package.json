{
  "name": "@localive/react",
  "version": "0.1.3",
  "description": "React bindings for Localive. Add the provider and edit translations inline as the app runs.",
  "license": "MIT",
  "author": "Ali Gamal <aga@luftborn.com> (https://github.com/Arigatouz)",
  "homepage": "https://localive.vercel.app/guides/react/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/client-react"
  },
  "keywords": [
    "i18n",
    "react",
    "translation",
    "localization",
    "live-editing",
    "localive",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@localive/core": "^0.1.3"
  },
  "devDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^25.0.0",
    "@localive/core": "^0.1.3"
  },
  "nx": {
    "tags": [
      "scope:client:react",
      "type:lib"
    ]
  }
}

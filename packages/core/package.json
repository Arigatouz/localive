{
  "name": "@localive/core",
  "version": "0.1.4",
  "description": "The framework-agnostic engine behind Localive's in-app translation editing. No runtime dependencies.",
  "license": "MIT",
  "author": "Ali Gamal <aga@luftborn.com> (https://github.com/Arigatouz)",
  "homepage": "https://localive.vercel.app/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/core"
  },
  "keywords": [
    "i18n",
    "l10n",
    "internationalization",
    "localization",
    "translation",
    "live-editing",
    "developer-tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {},
  "peerDependencies": {},
  "dependencies": {},
  "nx": {
    "tags": [
      "scope:core",
      "type:lib"
    ]
  }
}

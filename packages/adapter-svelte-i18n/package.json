{
  "name": "@localive/adapter-svelte-i18n",
  "version": "0.1.4",
  "description": "Use Localive with svelte-i18n and edit translations while your Svelte app runs.",
  "license": "MIT",
  "author": "Ali Gamal <aga@luftborn.com> (https://github.com/Arigatouz)",
  "homepage": "https://localive.vercel.app/concepts/adapters/",
  "bugs": "https://github.com/Arigatouz/localive/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arigatouz/localive.git",
    "directory": "packages/adapter-svelte-i18n"
  },
  "keywords": [
    "i18n",
    "svelte-i18n",
    "svelte",
    "translation",
    "localization",
    "live-editing",
    "localive"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "svelte-i18n": ">=4.0.0",
    "@localive/core": "^0.1.3"
  },
  "devDependencies": {
    "@localive/core": "^0.1.3"
  },
  "nx": {
    "tags": [
      "scope:adapter",
      "type:lib"
    ]
  }
}

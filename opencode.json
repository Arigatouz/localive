{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "nx-mcp": {
      "type": "local",
      "command": ["npx", "nx", "mcp"],
      "enabled": true
    },
    "playwright-mcp": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--headless"],
      "enabled": true
    }
  }
}
